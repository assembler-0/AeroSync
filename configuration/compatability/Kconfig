menu "compatability"

config SPINLOCK_LINUX_COMPAT
    bool "Enable common Linux macros/methods for spinlock"
    default y
    help
      Enables Linux-style spinlock definitions

config ATOMIC_LINUX_COMPAT
    bool "Enable common Linux atomic-related macros/methods"
    default y
    help
      Enables Linux-style atomic operations

config BOCHS_COMPAT
    bool "Bochs emulator compatibility mode"
    default n
    help
      Enable compatibility mode for Bochs x86 emulator.
      Disables SSE/SSE2/SSE3+ instruction generation and runtime
      CPU feature enablement that Bochs cannot properly emulate.
      
      Only enable this when building specifically for Bochs testing.
      This will reduce performance on real hardware.

endmenu