menu "unified driver model (udm) & system interfaces"

config UDM_CORE
    bool "Unified Driver Model (UDM) Core"
    default y
    help
      The core infrastructure for device, driver, bus, and class
      management. This is the foundation of the AeroSync hardware
      abstraction layer.

config SYSINTF
    bool "Legacy System Interface Compatibility"
    select UDM_CORE
    default y
    help
      Enables the unified subsystem APIs (Block, PCI, TTY, etc.) 
      that were formerly part of the standalone sysintf layer.
      These are now natively integrated into UDM.

config UDM_BLOCK
    bool "Block Device Subsystem"
    depends on UDM_CORE
    default y
    help
      Enable support for block devices (disks, partitions).
      Provides the unified block_read/write/flush API.

config UDM_CHAR
    bool "Character Device Subsystem"
    depends on UDM_CORE
    default y
    help
      Enable support for character devices (terminals, serial, etc.).

config UDM_PCI
    bool "PCI Bus Support"
    depends on UDM_CORE
    default y
    help
      Enable UDM support for the PCI bus, including dynamic
      config space access provider selection.

config UDM_ACPI
    bool "ACPI Device Support"
    depends on UDM_CORE
    default y
    help
      Enable UDM support for ACPI-enumerated devices and the
      ACPI bus type.

config UDM_PLATFORM
    bool "Platform Bus Support"
    depends on UDM_CORE
    default y
    help
      Enable support for the Platform Bus, used for non-discoverable
      hardware components.

config UDM_MANAGED_RESOURCES
    bool "Managed Device Resources (devres)"
    depends on UDM_CORE
    default y
    help
      Enable support for managed resources (devm_* API). This allows
      drivers to allocate resources that are automatically freed when
      the driver is detached from the device.

config DEBUG_DRIVER_MODEL
    bool "Driver Model Debugging"
    depends on UDM_CORE
    default n
    help
      Enable verbose logging for device/driver registration,
      binding, and lifecycle events.

config SYS_BUS_DEBUG
    bool "Bus Debugging"
    depends on UDM_CORE
    default n
    help
      Enable specific debugging for bus registration and enumeration.

config UDM_ORCHESTRATION
    bool "Global Lifecycle Orchestration"
    depends on UDM_CORE
    default y
    help
      Enable high-level driver orchestration APIs for system-wide
      driver lifecycle management (suspend_all, resume_all, etc.).

config DEBUG_UDM
    bool "UDM Lifecycle Debugging"
    depends on UDM_ORCHESTRATION
    default n
    help
      Enable verbose logging for UDM operations including
      suspend, resume, stop, and restart events.

config UDM_EMERGENCY_STOP
    bool "UDM Emergency Stop Support"
    depends on UDM_ORCHESTRATION
    default y
    help
      Enable emergency stop functionality for critical system
      failures. This allows immediate driver halt without
      error checking.

config UDM_SUSPEND_TIMEOUT_MS
    int "UDM Suspend Timeout (milliseconds)"
    depends on UDM_ORCHESTRATION
    default 5000
    range 1000 30000
    help
      Maximum time to wait for a driver to suspend before
      considering it failed.

endmenu